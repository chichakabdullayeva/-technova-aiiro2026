# Milli Kiber-DNT — Environment Configuration (example)
# Copy to .env and fill in your values
# DO NOT commit .env to version control!

# Login credentials
KIBER_DNT_USERNAME=admin
KIBER_DNT_PASSWORD=change_this_password

# Backend secret token
KIBER_DNT_SECRET_TOKEN=change_this_token

# Network scanning
KIBER_DNT_SUBNET=10.10.40.0/24

# EPSS API
KIBER_DNT_EPSS_TIMEOUT=10

# WAF deployment (set to true to enable real Snort/Suricata deployment)
KIBER_DNT_DEPLOY_RULES=false

# Ollama LLM
KIBER_DNT_OLLAMA_URL=http://localhost:11434
KIBER_DNT_LLM_MODEL=llama3.1:8b
